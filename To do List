tasks = []

while True:
    print("\nTO-DO LIST")
    print("1.Add Task")
    print("2.Show Tasks")
    print("3.Remove Task")
    print("4.Exit")

    choice = input("Enter Choice: ")

    # Add Task
    if choice == "1":
        task = input("Enter Task: ")
        tasks.append(task)
        print("Task Added")

    # Show Tasks
    elif choice == "2":
        print("\nYour Tasks:")
        
        if len(tasks) == 0:
            print("No Tasks Available")
        
        for task in tasks:
            print("-", task)

    # Remove Task
    elif choice == "3":
        task = input("Enter task name to remove: ")

        if task in tasks:
            tasks.remove(task)
            print("Task Removed")
        else:
            print("Task Not Found")

    # Exit
    elif choice == "4":
        print("Program Closed")
        break

    else:
        print("Wrong Choice")
